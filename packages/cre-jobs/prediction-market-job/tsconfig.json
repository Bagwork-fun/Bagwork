{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["main.ts", "gemini.ts", "evm.ts", "types.ts"],
  "exclude": ["node_modules"]
}
